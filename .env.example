# Runtime config overrides
# Copy this file to .env and fill in values

# Map tile URL (optional – defaults to OpenStreetMap)
# NUXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Google Places API key (enables real-time fuel prices)
# Get one at https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" in your Google Cloud project
NUXT_GOOGLE_PLACES_API_KEY=
